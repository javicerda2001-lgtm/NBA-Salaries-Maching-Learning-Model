#READ DATASETS
df = pd.read_csv('/content/NBA Player Stats and Salaries_2000-2025.csv')
df_salarycap = pd.read_csv('NBA SALARY CAP TFM.csv', sep=';')
df_salarycap = df_salarycap.rename(columns={
    'year': 'Year',
    'Salary Cap': 'Salary_Cap'
})

#MERGING DATASETS WITH LEFT JOIN
df = pd.merge(df, df_salarycap, on='Year', how='left')

#CREATING NEW VARIABLE TO NORMALIZE THE MODEL
df['Cap_Percentage'] = df['Salary'] / df['Salary_Cap']

----------------------------------------------------------------------------------------
#DATA CLEANING (10m Filter)
df_clean = df[df['MP'] >= 10].copy()

#CLUSTERING AND PCA
from sklearn.preprocessing import StandardScaler
from sklearn.decomposition import PCA
from sklearn.cluster import KMeans
import matplotlib.pyplot as plt
import numpy as np

# 1. Define variables  for clustering
features_clustering_full = features_to_scale + ['Cap_Percentage']

X_full_data = df_clean[features_clustering_full]

# 2.StandardScaler
scaler_full = StandardScaler()
X_scaled_full = scaler_full.fit_transform(X_full_data)
)

# 3.PCA
pca_full_test = PCA()
pca_full_test.fit(X_scaled_full)

varianza_acumulada_full = np.cumsum(pca_full_test.explained_variance_ratio_)

n_components_full = np.where(varianza_acumulada_full >= 0.80)[0][0] + 1

# Apply PCA with optimal number of components
pca_full = PCA(n_components=n_components_full, random_state=42)
X_pca_full = pca_full.fit_transform(X_scaled_full)


# 4.Elbow Method for K-Means
inercia_full = []
rango_k_full = range(1, 13) 
for k in rango_k_full:
    kmeans_elbow = KMeans(n_clusters=k, random_state=42, n_init=10)
    kmeans_elbow.fit(X_pca_full)
    inercia_full.append(kmeans_elbow.inertia_)

# 5.Elbow Method  Graph
plt.figure(figsize=(10, 6))
plt.plot(rango_k_full, inercia_full, marker='o', linestyle='--', color='green', linewidth=2)
plt.title('Método del Codo para K-Means (Dataset 2000-2025)', fontsize=14)
plt.xlabel('Número de Clusters (k)', fontsize=12)
plt.ylabel('Inercia', fontsize=12)
plt.xticks(rango_k_full)
plt.grid(True, linestyle=':', alpha=0.7)
plt.show()


# 6.Assign clusters to df_clean 
k_optimal = 4 
kmeans_full = KMeans(n_clusters=k_optimal, random_state=42, n_init=10)
etiquetas_pca_full = kmeans_full.fit_predict(X_pca_full)
df_clean['Cluster_PCA'] = etiquetas_pca_full

----------------------------------------------------------------------------------------------------------------------
#TRAINING THE MODEL

import numpy as np
from sklearn.ensemble import RandomForestRegressor
from sklearn.metrics import mean_absolute_error, median_absolute_error, r2_score

#1.Prepare variables
columnas_x = features_to_scale + ['Cluster_PCA']

#2.TIME MACHING, Train from 2000 to 2024 and validate in 2025
f_train = df_clean[df_clean['Year'] <= 2024].copy()
df_test = df_clean[df_clean['Year'] == 2025].copy()

X_train = df_train[columnas_x]
y_train_pct = df_train['Cap_Percentage']  

X_test = df_test[columnas_x]
y_test_pct = df_test['Cap_Percentage']
y_test_dollars = df_test['Salary'] 

# 3. RANDOM FOREST

rf_historico = RandomForestRegressor(
    n_estimators=200,
    max_depth=10,
    min_samples_split=5,
    random_state=42
)
rf_historico.fit(X_train, y_train_pct)

# 4. PREDICTION (2025)
predicciones_pct_2025 = rf_historico.predict(X_test)

# 5. TRANSLATION TO  REAL DOLARS 
# multiply the predicted percentage by each team's or player's 2025 cap.
predicciones_dollars_2025 = predicciones_pct_2025 * df_test['Salary_Cap']

# 6. EVALUATION OF THE MODEL
r2_historico = r2_score(y_test_dollars, predicciones_dollars_2025)
mae_historico = mean_absolute_error(y_test_dollars, predicciones_dollars_2025) / 1000000
medae_historico = median_absolute_error(y_test_dollars, predicciones_dollars_2025) / 1000000

print(f"✅ Entrenamiento y Predicción completados con éxito.\n")
print(f"📊 R^2 en Temporada 2025 (Modelo Histórico): {r2_historico:.2f}")
print(f"💰 Error Medio (MAE): ${mae_historico:.2f} Millones")
print(f"🎯 Error Mediano (MedAE) 2025: ${medae_historico:.2f} Millones")



